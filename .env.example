# Frontend Configuration
# Copy this file to .env.local and fill in your values

# API URL (leave empty for same-origin /api in production)
VITE_API_URL=http://localhost:3000

# === Added in v0.5.1 ===
# Redis (for API caching)
REDIS_URL=redis://localhost:6379

# Webhooks
WEBHOOK_SECRET=your_webhook_signing_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Relayer Configuration
RELAYER_PRIVATE_KEY=your_relayer_private_key
RELAYER_MIN_GAS_BALANCE=0.01

# Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Feature Flags
NEXT_PUBLIC_ENABLE_TIER_3=true
NEXT_PUBLIC_ENABLE_TIER_4=true
NEXT_PUBLIC_ENABLE_USERNAMES=true
NEXT_PUBLIC_ENABLE_MERCHANT_API=false
